 subsets 2 with duplicate elements using bt manuplation
class Solution:
    def subsetsWithDup(self, nums: List[int]) -> List[List[int]]:
        ans=[]
        nums.sort()
        for i in range(1<<len(nums)):
            temp = []
            for j in range(len(nums)):
                if i & (1<<j):
                    temp.append(nums[j])
            if temp not in ans:
                ans.append(temp)
        return ans
